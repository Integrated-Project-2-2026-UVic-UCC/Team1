<mujoco model="quad_bot">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
    <option gravity="0 0 -9.81" timestep="0.002"/>

    <default>
        <joint damping="0.5" armature="0.01" frictionloss="0.1"/>
        <geom friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1" rgba="0.8 0.8 0.8 1"/>
    </default>

    <worldbody>
    <!-- yas e genera con env_cfgs -->
        <!-- <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <geom name="floor" type="plane" size="10 10 .1" rgba="0.8 0.8 0.8 1"/> -->

        <!-- CUERPO CENTRAL (trunk) -->
        <body name="trunk" pos="0 0 0.25">
            <freejoint name="root"/>
            <inertial pos="0 0 0" mass="1.9" diaginertia="0.004 0.008 0.010"/>
            <geom name="trunk_collision" type="box" size="0.12 0.07 0.04" rgba="0.1 0.1 0.1 1"/>
            
            <site name="imu_site" pos="0 0 0" size="0.01" type="sphere" rgba="1 1 1 1"/>

            <!-- SITES de referencia para el algoritmo del ANYmal C -->
            <site name="FL" pos="0.1 0.06 0" size="0.01" rgba="1 0 0 0"/>
            <site name="FR" pos="0.1 -0.06 0" size="0.01" rgba="0 1 0 0"/>
            <site name="RL" pos="-0.1 0.06 0" size="0.01" rgba="0 0 1 0"/>
            <site name="RR" pos="-0.1 -0.06 0" size="0.01" rgba="1 1 0 0"/>

            <!-- TODO: revisar los rangos de movimiento de las articulaciones  -->

            <!-- PATA DELANTERA IZQUIERDA (FL) -->
            <body name="FL_hip" pos="0.1 0.06 0">
                <joint name="FL_hip_roll" axis="1 0 0" range="-30 30"/>
                <geom name="FL_hip_collision" type="sphere" size="0.02" rgba="0.8 0 0 1"/>
                <body name="FL_thigh" pos="0 0.03 0">
                    <joint name="FL_hip_pitch" axis="0 1 0" range="-60 60"/>
                    <geom name="FL_thigh_collision" type="capsule" size="0.015" fromto="0 0 0 0 0 -0.1" rgba="0.8 0 0 1"/>
                    <body name="FL_calf" pos="0 0 -0.1">
                        <joint name="FL_knee" axis="0 1 0" range="-100 0"/>
                        <geom name="FL_calf_collision" type="capsule" size="0.01" fromto="0 0 0 0 0 -0.1" rgba="0.8 0 0 1"/>
                        <body name="FL_foot" pos="0 0 -0.1">
                            <geom name="FL_foot_collision" type="sphere" size="0.02" rgba="0 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- PATA DELANTERA DERECHA (FR) -->
            <body name="FR_hip" pos="0.1 -0.06 0">
                <joint name="FR_hip_roll" axis="-1 0 0" range="-30 30"/>
                <geom name="FR_hip_collision" type="sphere" size="0.02" rgba="0 0.8 0 1"/>
                <body name="FR_thigh" pos="0 -0.03 0">
                    <joint name="FR_hip_pitch" axis="0 1 0" range="-60 60"/>
                    <geom name="FR_thigh_collision" type="capsule" size="0.015" fromto="0 0 0 0 0 -0.1" rgba="0 0.8 0 1"/>
                    <body name="FR_calf" pos="0 0 -0.1">
                        <joint name="FR_knee" axis="0 1 0" range="-100 0"/>
                        <geom name="FR_calf_collision" type="capsule" size="0.01" fromto="0 0 0 0 0 -0.1" rgba="0 0.8 0 1"/>
                        <body name="FR_foot" pos="0 0 -0.1">
                            <geom name="FR_foot_collision" type="sphere" size="0.02" rgba="0 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- PATA TRASERA IZQUIERDA (RL) -->
            <body name="RL_hip" pos="-0.1 0.06 0">
                <joint name="RL_hip_roll" axis="1 0 0" range="-30 30"/>
                <geom name="RL_hip_collision" type="sphere" size="0.02" rgba="0 0 0.8 1"/>
                <body name="RL_thigh" pos="0 0.03 0">
                    <joint name="RL_hip_pitch" axis="0 1 0" range="-60 60"/>
                    <geom name="RL_thigh_collision" type="capsule" size="0.015" fromto="0 0 0 0 0 -0.1" rgba="0 0 0.8 1"/>
                    <body name="RL_calf" pos="0 0 -0.1">
                        <joint name="RL_knee" axis="0 1 0" range="-100 0"/>
                        <geom name="RL_calf_collision" type="capsule" size="0.01" fromto="0 0 0 0 0 -0.1" rgba="0 0 0.8 1"/>
                        <body name="RL_foot" pos="0 0 -0.1">
                            <geom name="RL_foot_collision" type="sphere" size="0.02" rgba="0 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- PATA TRASERA DERECHA (RR) -->
            <body name="RR_hip" pos="-0.1 -0.06 0">
                <joint name="RR_hip_roll" axis="-1 0 0" range="-30 30"/>
                <geom name="RR_hip_collision" type="sphere" size="0.02" rgba="0.8 0.8 0 1"/>
                <body name="RR_thigh" pos="0 -0.03 0">
                    <joint name="RR_hip_pitch" axis="0 1 0" range="-60 60"/>
                    <geom name="RR_thigh_collision" type="capsule" size="0.015" fromto="0 0 0 0 0 -0.1" rgba="0.8 0.8 0 1"/>
                    <body name="RR_calf" pos="0 0 -0.1">
                        <joint name="RR_knee" axis="0 1 0" range="-100 0"/>
                        <geom name="RR_calf_collision" type="capsule" size="0.01" fromto="0 0 0 0 0 -0.1" rgba="0.8 0.8 0 1"/>
                        <body name="RR_foot" pos="0 0 -0.1">
                            <geom name="RR_foot_collision" type="sphere" size="0.02" rgba="0 0 0 1"/>
                        </body>
                    </body>
                </body>
             </body>
        </body>
    </worldbody>

    <sensor>
        <accelerometer name="imu_accel" site="imu_site"/>
        <gyro name="imu_ang_vel" site="imu_site"/>
        <velocimeter name="imu_lin_vel" site="imu_site"/>
    </sensor>
</mujoco>