<mujoco model="pata_12_dof_unitree">
    <option gravity="0 0 -9.81" timestep="0.01"/>

    <worldbody>
        <geom name="suelo" type="plane" size="2 2 .1" rgba="0.5 0.5 0.5 1"/>
        <light diffuse=".8 .8 .8" pos="0 0 3" dir="0 0 -1"/>

        <!-- BASE DEL ROBOT (Torso) -->
        <body name="torso" pos="0 0 0.5">
            <geom type="box" size="0.1 0.08 0.04" rgba="0.2 0.2 0.2 1"/>
            
            <!-- 1. ARTICULACIÓN DE ABDUCCIÓN (Roll) -->
            <!-- Eje X: 1 0 0 (Permite abrir la pata hacia los lados) -->
            <body name="hip_roll_link" pos="0.1 0.08 0">
                <joint name="cadera_roll" type="hinge" axis="1 0 0" range="-30 30" damping="0.5"/>
                <geom type="sphere" size="0.03" rgba="0.8 0.8 0.8 1"/> <!-- Motor 1 visual -->

                <!-- 2. ARTICULACIÓN DE FLEXIÓN (Pitch) -->
                <!-- Eje Y: 0 1 0 (Mueve el muslo adelante/atrás) -->
                <body name="muslo" pos="0 0.04 0">
                    <joint name="cadera_pitch" type="hinge" axis="0 1 0" range="-60 60" damping="0.5"/>
                    <geom type="capsule" size="0.02" fromto="0 0 0 0 0 -0.15" rgba="1 0 0 1"/>

                    <!-- 3. ARTICULACIÓN DE RODILLA (Knee Pitch) -->
                    <!-- Eje Y: 0 1 0 (Dobla la rodilla) -->
                    <body name="espinilla" pos="0 0 -0.15">
                        <joint name="rodilla" type="hinge" axis="0 1 0" range="-100 0" damping="0.5"/>
                        <geom type="capsule" size="0.02" fromto="0 0 0 0 0 -0.15" rgba="0 1 0 1"/>
                        
                        <!-- PIE -->
                        <body name="pie" pos="0 0 -0.15">
                            <geom type="sphere" size="0.025" rgba="0 0 0 1" friction="1 0.005 0.0001"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- ACTUADORES: Los 3 motores de esta pata -->
    <actuator>
    <!-- 
        kp: es la fuerza del servo. 
        forcerange: limita la fuerza máxima para que el motor no sea "infinito" 
        (ajústalo según el torque de tus Feetech).
        -->
        <position name="srv_roll" joint="cadera_roll" kp="20" kv="1.5" ctrlrange="-0.6 0.6" forcerange="-1.9 1.9"/>
	<position name="srv_pitch" joint="cadera_pitch" kp="20" kv="1.5" ctrlrange="-1.2 1.2" forcerange="-1.9 1.9"/>
	<position name="srv_rodilla" joint="rodilla" kp="20" kv="1.5" ctrlrange="-1.8 0" forcerange="-1.9 1.9"/>
    </actuator>
	    
</mujoco>
